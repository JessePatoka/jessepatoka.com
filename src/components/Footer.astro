<footer class="border-t border-[var(--color-border)]/30 px-6 py-8">
  <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-4 sm:flex-row">
    <p class="text-sm text-[var(--color-text-secondary)]">
      &copy; {new Date().getFullYear()} Jesse Patoka. All rights reserved.
    </p>
    <p class="text-xs text-[var(--color-text-secondary)]/50">
      Built with
